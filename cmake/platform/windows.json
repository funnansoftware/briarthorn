{
    "version": 7,
    "include": [
        "../compiler/msvc.json",
        "../compiler/zig.json",
        "../config/binaryDir.json",
        "../config/debug.json",
        "../config/ninja.json",
        "../config/release.json",
        "../config/vcpkg.json",
        "../host/x64-windows.json",
        "../target/x64-windows.json"
    ],
    "configurePresets": [
        {
            "name": "x64-windows-msvc-debug",
            "inherits": [
                "compiler-msvc",
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "host-x64-windows",
                "target-x64-windows"
            ]
        },
        {
            "name": "x64-windows-msvc-release",
            "inherits": [
                "compiler-msvc",
                "config-binaryDir",
                "config-ninja",
                "config-release",
                "config-vcpkg",
                "host-x64-windows",
                "target-x64-windows"
            ]
        },
        {
            "name": "x64-windows-zig-debug",
            "inherits": [
                "compiler-zig",
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "host-x64-windows",
                "target-x64-windows"
            ]
        },
        {
            "name": "x64-windows-zig-release",
            "inherits": [
                "compiler-zig",
                "config-binaryDir",
                "config-ninja",
                "config-release",
                "config-vcpkg",
                "host-x64-windows",
                "target-x64-windows"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "x64-windows-msvc-debug",
            "configurePreset": "x64-windows-msvc-debug"
        },
        {
            "name": "x64-windows-msvc-release",
            "configurePreset": "x64-windows-msvc-release"
        },
        {
            "name": "x64-windows-zig-debug",
            "configurePreset": "x64-windows-zig-debug"
        },
        {
            "name": "x64-windows-zig-release",
            "configurePreset": "x64-windows-zig-release"
        }
    ],
    "testPresets": [
        {
            "name": "x64-windows-msvc-debug",
            "configurePreset": "x64-windows-msvc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-windows-msvc-release",
            "configurePreset": "x64-windows-msvc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-windows-zig-debug",
            "configurePreset": "x64-windows-zig-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-windows-zig-release",
            "configurePreset": "x64-windows-zig-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}