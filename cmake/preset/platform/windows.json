{
    "version": 7,
    "include": [
        "../compiler/msvc.json",
        "../compiler/zig-windows.json",
        "../config/binaryDir.json",
        "../config/debug.json",
        "../config/ninja.json",
        "../config/release.json",
        "../config/vcpkg.json",
        "../target/windows.json",
        "../target/windows-zig.json"
    ],
    "configurePresets": [
        {
            "name": "windows-msvc-debug",
            "inherits": [
                "compiler-msvc",
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "target-windows"
            ]
        },
        {
            "name": "windows-msvc-release",
            "inherits": [
                "compiler-msvc",
                "config-binaryDir",
                "config-ninja",
                "config-release",
                "config-vcpkg",
                "target-windows"
            ]
        },
        {
            "name": "windows-zig-debug",
            "inherits": [
                "compiler-zig-windows",
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "target-windows-zig"
            ]
        },
        {
            "name": "windows-zig-release",
            "inherits": [
                "compiler-zig-windows",
                "config-binaryDir",
                "config-ninja",
                "config-release",
                "config-vcpkg",
                "target-windows-zig"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "windows-msvc-debug",
            "configurePreset": "windows-msvc-debug"
        },
        {
            "name": "windows-msvc-release",
            "configurePreset": "windows-msvc-release"
        },
        {
            "name": "windows-zig-debug",
            "configurePreset": "windows-zig-debug"
        },
        {
            "name": "windows-zig-release",
            "configurePreset": "windows-zig-release"
        }
    ],
    "testPresets": [
        {
            "name": "windows-msvc-debug",
            "configurePreset": "windows-msvc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-msvc-release",
            "configurePreset": "windows-msvc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-zig-debug",
            "configurePreset": "windows-zig-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-zig-release",
            "configurePreset": "windows-zig-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
