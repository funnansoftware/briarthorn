{
    "version": 7,
    "include": [
        "../compiler/android-ndk.json",
        "../config/binaryDir.json",
        "../config/debug.json",
        "../config/ninja.json",
        "../config/release.json",
        "../config/vcpkg.json",
        "../target/android.json"
    ],
    "configurePresets": [
        {
            "name": "android-debug",
            "inherits": [
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "compiler-android-ndk",
                "target-android"
            ]
        },
        {
            "name": "android-release",
            "inherits": [
                "config-binaryDir",
                "config-release",
                "config-ninja",
                "config-vcpkg",
                "compiler-android-ndk",
                "target-android"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "android-debug",
            "configurePreset": "android-debug"
        },
        {
            "name": "android-release",
            "configurePreset": "android-release"
        }
    ],
    "testPresets": [
        {
            "name": "android-debug",
            "configurePreset": "android-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "android-release",
            "configurePreset": "android-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
