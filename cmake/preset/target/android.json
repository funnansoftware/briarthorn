{
    "version": 7,
    "configurePresets": [
        {
            "name": "target-android",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "ANDROID_ABI": "arm64-v8a",
                "ANDROID_PLATFORM": "android-35",
                "VCPKG_HOST_TRIPLET": "x64-linux",
                "VCPKG_TARGET_TRIPLET": "arm64-android"
            }
        }
    ]
}
