{
    "version": 7,
    "configurePresets": [
        {
            "name": "target-linux",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "VCPKG_HOST_TRIPLET": "x64-linux",
                "VCPKG_TARGET_TRIPLET": "x64-linux"
            }
        }
    ]
}
