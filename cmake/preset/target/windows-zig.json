{
    "version": 7,
    "configurePresets": [
        {
            "name": "target-windows-zig",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "VCPKG_HOST_TRIPLET": "x64-windows-static-md",
                "VCPKG_TARGET_TRIPLET": "x64-mingw-static"
            }
        }
    ]
}
