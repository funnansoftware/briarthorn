{
    "version": 7,
    "configurePresets": [
        {
            "name": "compiler-zig-linux",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "CMAKE_CXX_COMPILER": "${sourceDir}/scripts/zig++.sh",
                "CMAKE_C_COMPILER": "${sourceDir}/scripts/zigcc.sh",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Werror -pedantic",
                "CMAKE_C_FLAGS": "-Wall -Wextra -Werror -pedantic"
            }
        }
    ]
}